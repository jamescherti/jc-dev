set -e
set -u

usage() {
  echo "Usage: ${0##*/} <chroot_directory>" >&2
  exit 1
}

cleanup() {
  echo "Cleaning up mounts..."
  # Unmount in reverse order of mounting as a best practice
  for item in run sys proc dev; do
    if mountpoint -q "$item"; then
      umount "$item" || echo "Warning: failed to unmount $item" >&2
    fi
  done
}

main() {
  if [ "$(id -u)" -ne "0" ]; then
    echo "Error: you need root privileges to run this script." >&2
    exit 1
  fi

  if [ "$#" -ne 1 ]; then
    usage
  fi

  CHROOT_DIR="$1"

  if [ ! -d "$CHROOT_DIR" ]; then
    echo "Error: Directory '$CHROOT_DIR' does not exist." >&2
    exit 1
  fi

  cd "$CHROOT_DIR"

  trap cleanup EXIT INT TERM

  echo "Prepare chroot: $(pwd)"
  echo "Press enter..."
  read -r -p "" _variable </dev/tty

  for item in dev proc sys run; do
    if ! mountpoint -q "$item"; then
      mount -o bind "/$item" "$item"
    fi
  done

  chroot . /bin/bash -l
}

main "$@"
