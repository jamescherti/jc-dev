set -Eeuo pipefail

usage() {
  printf 'Usage: %s <chroot_directory>\n' "${0##*/}" >&2
  exit 1
}

cleanup() {
  local target

  for target in \
    "$CHROOT_DIR/run" \
    "$CHROOT_DIR/sys" \
    "$CHROOT_DIR/proc" \
    "$CHROOT_DIR/dev"; do
    if mountpoint -q "$target"; then
      umount -R "$target" \
        || printf 'Warning: failed to unmount %s\n' "$target" >&2
    fi
  done
}

require_root() {
  if [[ "$(id -u)" -ne 0 ]]; then
    printf 'Error: root privileges required\n' >&2
    exit 1
  fi
}

validate_chroot() {
  if [[ ! -d "$CHROOT_DIR" ]]; then
    printf 'Error: directory does not exist: %s\n' "$CHROOT_DIR" >&2
    exit 1
  fi

  if [[ ! -x "$CHROOT_DIR/bin/bash" ]]; then
    printf 'Error: missing executable: %s/bin/bash\n' "$CHROOT_DIR" >&2
    exit 1
  fi
}

mount_fs() {
  mkdir -p \
    "$CHROOT_DIR/dev" \
    "$CHROOT_DIR/proc" \
    "$CHROOT_DIR/sys" \
    "$CHROOT_DIR/run"

  mount --rbind /dev "$CHROOT_DIR/dev"
  mount --make-rslave "$CHROOT_DIR/dev"

  mount -t proc proc "$CHROOT_DIR/proc"

  mount --rbind /sys "$CHROOT_DIR/sys"
  mount --make-rslave "$CHROOT_DIR/sys"

  mount --bind /run "$CHROOT_DIR/run"
}

main() {
  require_root

  if [[ "$#" -ne 1 ]]; then
    usage
  fi

  CHROOT_DIR="$(realpath "$1")"

  validate_chroot

  trap cleanup EXIT INT TERM

  printf 'Preparing chroot: %s\n' "$CHROOT_DIR"

  mount_fs

  chroot "$CHROOT_DIR" /bin/bash -l
}

main "$@"
