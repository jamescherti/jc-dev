set -euo pipefail

main() {
  # Ensure we have at least 3 arguments
  if [[ $# -lt 3 ]]; then
    echo "Usage: run_every <seconds> <reference_file> <command...>" >&2
    return 1
  fi

  local interval="$1"
  local lock_file="$2"
  shift 2
  local command=("$@")

  # Validate that the interval is a positive integer
  if ! [[ "$interval" =~ ^[0-9]+$ ]]; then
    echo "Error: <seconds> must be a positive integer." >&2
    return 1
  fi

  # Ensure the directory exists
  mkdir -p "$(dirname "$lock_file")"

  local should_run=false

  if [[ -f "$lock_file" ]]; then
    local current_time
    current_time=$(date +%s)

    local last_run
    # Support both GNU stat (-c) and BSD/macOS stat (-f) for better portability
    last_run=$(stat -c %Y "$lock_file" 2>/dev/null || stat -f %m "$lock_file" 2>/dev/null)

    local elapsed
    elapsed=$((current_time - last_run))

    if [[ $elapsed -ge $interval ]]; then
      should_run=true
    else
      echo "[IGNORED] ${command[*]}"
    fi
  else
    # First time running: execute and create the file
    should_run=true
  fi

  if [[ "$should_run" == true ]]; then
    # Touch the lock file before execution to prevent concurrent processes
    # from initiating the same long-running command.
    touch "$lock_file"
    "${command[@]}"
  fi
}

main "$@"
