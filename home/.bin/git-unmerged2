"""Check if a repository should be released based on unmerged commits."""

import os
import subprocess
import sys
from pathlib import Path
from typing import Optional


def get_default_branch(repo_path: Path) -> Optional[str]:
    """
    Check the default branch of a Git repository using `git symbolic-ref`.

    :param repo_path: Path to the Git repository.
    :type repo_path: pathlib.Path
    :return: The default branch name or None if it cannot be determined.
    :rtype: typing.Optional[str]
    """
    try:
        # Get the default branch
        output: str = subprocess.run(["git", "-C", str(repo_path),
                                      "symbolic-ref",
                                      "refs/remotes/origin/HEAD"],
                                     stdout=subprocess.PIPE,
                                     text=True,
                                     check=True).stdout.strip()
        # Return the default branch
        return output.split("/")[-1]
    except subprocess.CalledProcessError:
        return None


def check_branch_exists(repo_path: Path, branch_name: str) -> bool:
    """
    Check if a branch exists in the repository.

    :param repo_path: Path to the Git repository.
    :type repo_path: pathlib.Path
    :param branch_name: The name of the branch to verify.
    :type branch_name: str
    :return: True if the branch exists, False otherwise.
    :rtype: bool
    """
    try:
        # Check if 'develop' branch exists
        subprocess.run(
            ["git", "-C", str(repo_path), "show-ref", "--verify", "--quiet",
             f"refs/heads/{branch_name}"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=True,
        )
        return True
    except subprocess.CalledProcessError:
        return False


def has_unmerged_commits(repo_path: Path, base_branch: str,
                         feature_branch: str) -> bool:
    """
    Check if the feature branch has commits not present in the base branch.

    :param repo_path: Path to the Git repository.
    :type repo_path: pathlib.Path
    :param base_branch: The base branch to compare against.
    :type base_branch: str
    :param feature_branch: The branch that might contain new commits.
    :type feature_branch: str
    :return: True if there are unmerged commits, False otherwise.
    :rtype: bool
    """
    try:
        result: subprocess.CompletedProcess[str] = subprocess.run(
            ["git", "-C", str(repo_path), "rev-list",
             f"{base_branch}..{feature_branch}"],
            stdout=subprocess.PIPE,
            text=True,
            check=True,
        )
        return bool(result.stdout.strip())
    except subprocess.CalledProcessError:
        return False


def unset_git_environment_variables() -> None:
    """
    Unset all environment variables that start with 'GIT_'.
    """
    key: str
    for key in list(os.environ):
        if key.startswith("GIT_"):
            del os.environ[key]


if __name__ == "__main__":
    unset_git_environment_variables()
    current_path: Path = Path.cwd()

    default_branch: Optional[str] = get_default_branch(current_path)
    if not default_branch:
        print("Could not determine the default branch.", file=sys.stderr)
        sys.exit(1)

    # If 'develop' does not exist, return the default branch
    develop_exists: bool = check_branch_exists(current_path, "develop")
    if not develop_exists:
        print(f"[IGNORE] {current_path}: 'develop' branch does not exist.")
        sys.exit(0)

    unmerged: bool = \
        has_unmerged_commits(current_path, default_branch, "develop")
    if unmerged:
        print(f"[UNMERGED] {current_path}: 'develop' has commits not "
              f"in '{default_branch}'")
    else:
        print(f"[CLEAN] {current_path}: 'develop' is fully merged "
              "into '{default_branch}'")
