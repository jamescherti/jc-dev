set -euo pipefail

git-is-clean

# Step 1: Find the default branch
# Attempt to resolve origin/HEAD first
DEFAULT_BRANCH=$(git rev-parse --abbrev-ref origin/HEAD 2>/dev/null \
  | sed 's|^origin/||')

# Fall back to main or master if origin/HEAD is not configured
if [ -z "$DEFAULT_BRANCH" ] || [ "$DEFAULT_BRANCH" = "HEAD" ]; then
  if git rev-parse --verify main >/dev/null 2>&1 \
    || git rev-parse --verify origin/main >/dev/null 2>&1; then
    DEFAULT_BRANCH="main"
  elif git rev-parse --verify master >/dev/null 2>&1 \
    || git rev-parse --verify origin/master >/dev/null 2>&1; then
    DEFAULT_BRANCH="master"
  else
    echo "Error: Default branch could not be determined." >&2
    exit 1
  fi
fi

# Determine the best reference to compare against (local or remote tracking)
if git rev-parse --verify "$DEFAULT_BRANCH" >/dev/null 2>&1; then
  COMPARE_REF="$DEFAULT_BRANCH"
elif git rev-parse --verify "origin/$DEFAULT_BRANCH" >/dev/null 2>&1; then
  COMPARE_REF="origin/$DEFAULT_BRANCH"
else
  echo "Error: Resolved default branch '$DEFAULT_BRANCH' does not" \
    "exist locally or on origin." >&2
  exit 1
fi

# Step 2: Identify references and commit SHAs
CURRENT_REF=$(git rev-parse --abbrev-ref HEAD)
CURRENT_SHA=$(git rev-parse HEAD)
TARGET_SHA=$(git rev-parse "$COMPARE_REF")

# Fail if the current branch name matches the default branch name
if [ "$CURRENT_REF" = "$DEFAULT_BRANCH" ]; then
  echo "Error: Current branch is already the" \
    "default branch '$DEFAULT_BRANCH'." >&2
  exit 1
fi

# Fail if the current commit hash matches the target branch commit hash
if [ "$CURRENT_SHA" = "$TARGET_SHA" ]; then
  echo "Error: Current reference is already at the same" \
    "commit as '$DEFAULT_BRANCH'." >&2
  exit 1
fi

# Step 3: Show differences and request confirmation
echo "Changes to be merged from '$CURRENT_REF' into '$DEFAULT_BRANCH'" \
  "(comparing against '$COMPARE_REF'):"
echo "--------------------------------------------------------"
echo "Incoming Commits:"
git log "${COMPARE_REF}..HEAD" --oneline

echo ""
echo "Diff Stat:"
git diff --stat "${COMPARE_REF}..HEAD"
echo "--------------------------------------------------------"

printf "Proceed with fast-forward merge and push of '%s' into '%s'? (y/N): " \
  "$CURRENT_REF" "$DEFAULT_BRANCH"
read -r response
if [[ ! "$response" =~ ^[Yy]$ ]]; then
  echo "Aborted: Operation canceled by user." >&2
  exit 1
fi

# Step 4: Perform the merge using standard checkout
echo "Checking out '$DEFAULT_BRANCH' and merging '$CURRENT_REF'..."
git checkout "$DEFAULT_BRANCH"

if ! git merge --ff-only "$CURRENT_REF"; then
  echo "Error: Fast-forward failed. '$DEFAULT_BRANCH' and " \
    "'$CURRENT_REF' have diverged." >&2
  git checkout "$CURRENT_REF"
  exit 1
fi

# Step 5: Push the updated default branch to remote and restore original branch
echo "Pushing '$DEFAULT_BRANCH' to origin..."
if ! git push origin "$DEFAULT_BRANCH"; then
  echo "Error: Failed to push '$DEFAULT_BRANCH' to origin." >&2
  git checkout "$CURRENT_REF"
  exit 1
fi

echo "Restoring original branch '$CURRENT_REF'..."
git checkout "$CURRENT_REF"

echo "Successfully merged and pushed '$DEFAULT_BRANCH'."
