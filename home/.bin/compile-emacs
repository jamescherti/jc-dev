# -Wl,-O2 - Instructs the linker to optimize layout of the binary. Helps reduce
# cache misses slightly.
#
# -Wl,--sort-common – Orders common symbols to improve memory locality. Small
# effect, generally safe.
#
# -Wl,--as-needed – Only links libraries that are actually used. Reduces the
# size of the executable and startup overhead. Useful for Emacs because it links
# many libraries.
#
# -Wl,-z,pack-relative-relocs – Reduces the size of relocations for
# position-independent executables. Slightly reduces memory usage and can
# improve startup speed.
#
# NOTE:
# In standard GNU ld, the optimization levels are strictly limited. GNU ld
# natively understands -O1 (which turns on hash table optimization) and -O2
# (which enables more aggressive string merging). However, -O3 is generally
# meaningless to standard linkers and is either silently ignored or downgraded
# to -O2.
export BASE_LDFLAGS="-Wl,-O2 -Wl,--sort-common \
  -Wl,--as-needed -Wl,-z,pack-relative-relocs"

if [[ $ID == "debian" ]] && [[ ${VERSION_ID:-} == "13" ]]; then
  export BASE_CFLAGS="$BASE_CFLAGS -I/usr/lib/gcc/x86_64-linux-gnu/12/include"
  export BASE_LDFLAGS="$BASE_LDFLAGS -L/usr/lib/gcc/x86_64-linux-gnu/12"
fi

# The -fno-semantic-interposition flag is an advanced compiler option that
# removes a strict ELF-standard optimization barrier, allowing for more
# aggressive inlining and interprocedural analysis.
#
# On ELF systems, externally visible symbols in shared objects are normally
# interposable at runtime (e.g., via LD_PRELOAD). Because of this, GCC must
# conservatively assume that these functions can change at runtime. This acts
# as a hard barrier that inhibits optimizations such as:
# - Function inlining across boundaries
# - Constant propagation
# - Devirtualization
#
# -fno-semantic-interposition tells GCC to assume that functions defined within
# the current binary or shared object will not be overridden externally.
#
# Impact on Emacs
# ---------------
# While this flag became widely known after it produced measurable interpreter
# performance improvements for CPython builds, its impact on Emacs is much
# more nuanced.
#
# * For the Emacs C Core:
#   * Benefit: Small. Emacs is typically compiled as a main executable, not a
#     shared library. Even when compiled as a Position Independent Executable
#     (PIE), the compiler generally already knows that internal symbols will
#     not be interposed. The performance gain here is usually marginal and
#     highly dependent on compiler visibility and Link-Time Optimization (LTO).
#   * Drawback: None. You do not need to dynamically interpose internal Emacs
#     C functions at runtime.
#
# * For .eln Files (Native Compilation):
#   * Benefit: Small. While .eln files *are* compiled as shared objects (which
#     is where this flag technically applies most), interposition is not a
#     major performance bottleneck in this context. Emacs Lisp compiled output
#     is not call-heavy in the same way native C libraries are; execution time
#     is dominated by dynamic dispatch, garbage collection checks, and calls
#     back to C primitives. Breaking the interposition optimization barrier
#     here is technically correct but only beneficial in very narrow cases.
#   * Drawback: None. Elisp functions compiled into a .eln file are not
#     going to be interposed at the ELF/C linker level.
#
# TIP: Remove -fno-semantic-interposition and -fno-finite-math-only: These are
# largely redundant for the Emacs codebase. Emacs does not rely heavily on
# floating-point math, and it is not a shared library where semantic
# interposition rules heavily apply.
#
# app-editors/emacs: Excellent use of semantic-interposition.conf. Since you use
# Emacs, compile it with the jit USE flag (native compilation). The underlying
# libgccjit code compiler benefits immensely from your optimized LLVM/Clang and
# Python stacks.
export BASE_CFLAGS="$BASE_CFLAGS -fno-semantic-interposition"

# The -fno-finite-math-only flag prevents the compiler from assuming that
# floating-point operations never produce NaN or infinity values. This flag is
# mostly defensive because GCC does not enable -ffinite-math-only at -O2 or -O3
# by default, but it can help avoid unsafe assumptions if additional aggressive
# optimization flags are introduced later.
#
# TODO: Remove -fno-semantic-interposition and -fno-finite-math-only: These are
# largely redundant for the Emacs codebase. Emacs does not rely heavily on
# floating-point math, and it is not a shared library where semantic
# interposition rules heavily apply.
# export BASE_CFLAGS="$BASE_CFLAGS -fno-finite-math-only"
export BASE_CFLAGS="$BASE_CFLAGS -fno-finite-math-only"

# Applying -fno-plt to the Emacs Executable (C Core)
# -----------------------------------------------------
# Benefits
# - Execution Efficiency: Emacs relies heavily on external C libraries (libc,
#   GTK, tree-sitter, SQLite). Bypassing the Procedure Linkage Table (PLT)
#   saves a jump instruction on every single call to these libraries, yielding
#   a small but measurable reduction in CPU overhead.
# - Security Hardening: Because you are pairing this with -Wl,-z,now (bind
#   now), the dynamic linker resolves all symbols at startup. This allows the
#   Global Offset Table (GOT) to be marked strictly read-only, neutralizing a
#   common vector for memory corruption exploits.
#
# Tradeoffs
# - Startup Overhead: Because lazy binding is disabled, the operating system
#   dynamic linker must resolve every single external symbol before the emacs
#   binary is allowed to execute. This shifts computation to the startup phase,
#   adding a few milliseconds to the initial launch time.
#
# Applying -fno-plt to Native-Compiled .eln Files
# ---------------------------------------------------
# For maximum performance, the engineering recommendation is to exclude these
# specific flags from your native compilation variables.
#
# While they provide a measurable benefit when compiling the static Emacs C
# core, applying them to dynamically generated .eln files introduces a severe
# latency penalty that degrades the interactive feel of the editor.
#
# Emacs loads .eln files (which are standard ELF shared objects) on demand using
# the operating system's dlopen mechanism. This usually happens when an autoload
# is triggered the first time you run a command from a new package.
#
# Without the flags (Lazy Binding): The .eln file is loaded into memory
# instantly. The addresses for external Emacs C functions are resolved one by
# one, only when they are actually called for the first time. The overhead is
# spread out invisibly.
#
# With the flags (Bind Now): If you compile an .eln file with -fno-plt and link
# it with -Wl,-z,now, you force the dynamic linker to resolve every single
# external symbol inside that .eln file immediately during the dlopen call.
#
# For massive packages like Magit or LSP mode, resolving thousands of C
# primitives instantly will block the main Emacs thread. This manifests as a
# noticeable UI stutter or freeze right when you try to load the package. The
# microscopic execution speed gained by dropping the PLT jump instruction is
# entirely overshadowed by this severe load-time latency.
#
# How to Apply Them (If You Insist)
# ---------------------------------
# If your workflow involves loading all packages at startup (a "heavy init") and
# you want absolute maximum runtime throughput regardless of startup or load
# latency, you must apply both the compiler and linker flags together.
export BASE_CFLAGS="$BASE_CFLAGS -fno-plt"

# I am using -fno-plt in my BASE_CFLAGS, I must pair it with "bind now"
# semantics in the linker flags. This forces the dynamic linker to resolve all
# symbols at startup, fully bypassing lazy binding and allowing the Global
# Offset Table to be marked read-only.
#
# These slightly slow down startup time, but subtly speed up and smooth out
# runtime execution.
#
# Wl,-z,now: By default, Linux binaries use "lazy binding". When Emacs calls an
# external C library function (like a GTK drawing function or a tree-sitter
# parser) for the very first time, the program execution pauses while the
# dynamic linker resolves the memory address of that function. Adding -z,now
# forces the dynamic linker to resolve every single external symbol immediately
# when the binary is launched, before the program's main() function is even
# executed. It slightly slows down the initial startup of Emacs (usually by just
# a few milliseconds) because the operating system has to do all the symbol
# resolution math upfront. However, it speeds up your interactive runtime
# execution. Because all addresses are pre-calculated, you never encounter
# micro-stutters from the dynamic linker resolving symbols on the fly while you
# are typing or executing heavy Elisp operations.
#
# -Wl,-z,relro (Read-Only Relocations): What it does: This is a security
# hardening flag. Once the dynamic linker finishes resolving all the symbols
# (which is guaranteed to happen at startup thanks to the now flag), relro locks
# the Global Offset Table (GOT) in memory, marking it strictly read-only. This
# prevents specific types of memory corruption exploits where an attacker
# overwrites the GOT to hijack function calls.
# It has essentially zero impact on execution speed. The only minor overhead
# occurs during the load time when the operating system changes the memory page
# permissions to read-only.
#
# NOTE: No, it actually speeds up and smooths out your runtime execution, at the
# cost of a microscopic delay when you first launch the application.
export BASE_LDFLAGS="$BASE_LDFLAGS -Wl,-z,now -Wl,-z,relro"

# -fgraphite-identity & -floop-nest-optimize
#
# These two flags activate the Graphite polyhedral optimization framework.
# They analyze loops and rewrite them to maximize CPU cache locality
# (e.g., loop fusion, loop unrolling, and loop interchange).
#
# NOTE: These flags activate the GCC Graphite framework, which relies on
# polyhedral models to optimize complex, nested loops. This is excellent for
# heavy numerical computing or matrix mathematics. However, Emacs is essentially
# a C-based Lisp machine and text editor. Its performance bottlenecks are
# garbage collection, string manipulation, and Lisp evaluation. Using Graphite
# on Emacs will drastically increase your compilation time and memory usage. It
# often leads to compiler crashes or subtle runtime bugs without yielding faster
# execution.
#
# There is no tangible benefit to applying Graphite loop optimizations when
# compiling Emacs.
#
# Here is a technical breakdown of why those flags are ineffective for this
# specific codebase:
#
# * Data Structures: Emacs is built on dynamic, pointer-heavy data structures.
#   The core types are `Lisp_Object` variants (tagged pointers), linked lists
#   (cons cells), and the gap buffer for text management. Graphite relies on
#   static or highly predictable array bounds to perform polyhedral modeling.
#
# * Execution Profile: The execution time of Emacs is dominated by pointer
#   chasing during garbage collection, symbol lookups, and deep, unpredictable
#   call stacks from the Lisp evaluator. These are highly branch-dependent
#   workloads.
#
# * Lack of Affine Loops: For Graphite to optimize a loop, the loop must have
#   affine bounds (linear equations based on loop iterators) without complex
#   control flow inside the loop body. The C code in Emacs does not fit this
#   profile.
#
# * Compilation Overhead: Enabling `-floop-nest-optimize` forces GCC to perform
#   expensive data dependency analysis on code blocks that will ultimately be
#   rejected by the polyhedral model. This wastes CPU cycles and memory during
#   the build process without generating faster machine code.
#
# When configuring an Emacs build, you will see much better results by focusing
# on link-time optimizations and native compilation. Standard `-O2` or `-O3`
# combined with `-flto` (Link Time Optimization) yields a highly responsive
# binary. Furthermore, enabling native compilation (`--with-native-compilation`)
# using `libgccjit` is where the most significant performance gains for Lisp
# execution will occur.
#
# IMPORTANT: These flags: increase build time, increase compiler RAM usage, may
# trigger GCC bugs, rarely improve runtime performance measurably. These are
# essentially wasted on Emacs.
# export BASE_CFLAGS="$BASE_CFLAGS -fgraphite-identity -floop-nest-optimize"

# -fdevirtualize-at-ltrans: This flag is used during Link Time Optimization
# (LTO) to devirtualize C++ virtual function calls. Because the core of Emacs is
# written entirely in C and Emacs Lisp, there are no C++ classes or virtual
# methods to optimize. This flag doesn't do anything for your build.
#
# The Emacs core is written in C. C does not have virtual tables
# (vtables) or class inheritance in the way C++ does.
# The Result: The compiler will simply ignore this flag because there is no C++
# metadata to analyze. It is dead code in your build script.
# export BASE_CFLAGS="$BASE_CFLAGS -fdevirtualize-at-ltrans"

# -fipa-pta: This enables interprocedural pointer template analysis. While
# technically applicable to C code, it requires an enormous amount of RAM during
# the compilation phase. The performance gains for a codebase like Emacs are
# negligible, but the risk of the compiler running out of memory or generating
# broken binaries due to complex pointer aliasing is high.
#
# -fipa-pta enables interprocedural points-to analysis, allowing GCC to perform
# deeper pointer alias analysis across function boundaries. While technically
# applicable to C code, this optimization significantly increases compiler RAM
# usage and compilation time. For a codebase like Emacs, the runtime performance
# gains are usually negligible and may not justify the additional build
# complexity and resource consumption.
#
# NOTE: Enabling -fipa-pta for .eln compilation is generally not worthwhile.
# -fipa-pta is designed for deep interprocedural pointer alias analysis across
# large C codebases with complex pointer interactions. Native-compiled Elisp
# does not resemble that kind of workload:
# .eln code generated by libgccjit contains:
# heavy dynamic dispatch,
# runtime type checks,
# GC barriers,
# Lisp object tagging,
# frequent calls back into the Emacs runtime.
# -fipa-pta belongs more to large static C/C++ performance engineering workloads
# than to JIT-generated Emacs Lisp native code.
#
# Again: huge compile-time cost, minimal likely runtime gain, particularly poor
# fit for native-comp generated code. This belongs in HPC workloads, not Emacs.
if [[ "$ID" != "arch" || "$USE_CLANG" -eq 0 ]]; then
  export BASE_CFLAGS="$BASE_CFLAGS -fipa-pta"
fi

# Using the Memory Pool System (MPS) in Emacs introduces several drawbacks. It
# is largely experimental, so some Emacs packages or internal subsystems may not
# be fully compatible, potentially causing crashes or subtle memory issues.
# Building Emacs with MPS also adds complexity, requiring the library and
# headers to be correctly installed and configured, which can complicate
# cross-platform builds. Additionally, while MPS can improve memory management
# in certain workloads, it may introduce overhead in typical usage, and standard
# debugging or profiling tools may not fully support MPS, making memory issues
# harder to diagnose.
CONFIGURE_ARGS=(
  # In the configure.ac file, passing this flag sets the internal with_features
  # variable to no.
  --without-all

  # Enable internal assertions and type checks. Helpful during debugging or for
  # development builds.
  # --enable-checking=all
  # --enable-check-lisp-object-type

  # --disable-checking: Guarantees that expensive runtime assertions (such as
  # memory boundary checks) are stripped out entirely.
  --disable-checking

  # --disable-check-lisp-object-type: Ensures the internal Lisp_Object data type
  # is compiled as a simple native type rather than a strict C union or struct,
  # avoiding overhead during deep Lisp execution stacks.
  --disable-check-lisp-object-type

  # --disable-profiling: Ensures the compiler does not inject gprof instruction
  # profiling (-pg) into the binary.
  # TODO bug in this one: The Autoconf Quirk: In the previous step, I added
  # --disable-profiling to the configure options. However, the Emacs
  # configure.ac script evaluates this flag incorrectly. It checks if the
  # variable is simply non-empty (if test x$ac_enable_profiling != x). Because
  # --disable-profiling sets the value to no, the script evaluates xno != x as
  # true. This accidentally activates the -pg (gprof profiling) compiler flag.
  # --disable-profiling

  --with-gnutls

  # Use -fanalyzer and related options only if --enable-gcc-warnings,
  # as they slow GCC considerably.
  # nw="$nw -fanalyzer -Wno-analyzer-double-free -Wno-analyzer-malloc-leak"
  # The -fanalyzer framework increases compiler computational complexity,
  # blowing up compilation time and layout tracking memory overhead. Since you
  # are looking for production speed, remove --enable-gcc-warnings and
  # explicitly pass:
  --disable-gcc-warnings

  # I already handle it with -flto
  # it adds things that I don't need like -ffat-lto-objects This flag forces the
  # compiler to generate both LTO-compatible object code and standard machine
  # code. It essentially doubles the disk I/O and build time during the
  # compilation phase. Emacs is a final executable.
  # --enable-link-time-optimization

  --disable-build-details

  # --disable-year2038: On a 64-bit Arch system, your time_t is already 64-bit.
  # This flag is primarily for 32-bit systems trying to avoid or acknowledge the
  # 2038 bug. It adds no value to your build.
  # --disable-year2038

  # By default, many autotools-based projects hide the actual compiler/linker
  # commands and show simplified status lines like: This option disables that
  # simplification and shows the full compilation and linking commands used
  # (i.e., long gcc/ld command lines).
  # --disable-silent-rules

  # This flag enables automatic dependency tracking for C header files (.h),
  # such that when a header file changes, the appropriate source files (.c)
  # that include it will be recompiled. This relies on the GCC compiler's -MMD
  # and -MF flags.
  #
  # When a header file changes, only the affected .c files are recompiled.
  # This avoids either: Rebuilding the entire project unnecessarily, or
  # Missing necessary recompilation (leading to incorrect builds).
  #
  # Improved Build Efficiency, which is beneficial in large codebases like
  # Emacs, this option ensures that only modified and dependent files are
  # rebuilt. Over time, this saves significant build time.
  #
  # NOTE: This is only useful for developers who are constantly modifying
  # Emacs's own C source code. Since I am likely compiling a specific
  # branch/tag and then using it, this just adds a tiny bit of overhead to the
  # initial make process and generates extra .d files I don't need.
  # --enable-autodepend

  # Enable GC_REMEMBER_LAST_MARKED by default (it was disabled in Emacs 29)
  # to make it easier to debug difficult-to-reproduce GC problems
  # encountered by users.  This increases GC costs by about 5 %, which can
  # be avoided by turning the mark trace buffer back off using the new
  # --disable-gc-mark-trace option.
  # https://lists.gnu.org/archive/html/emacs-devel/2024-09/msg00240.html
  --disable-gc-mark-trace

  # The --with-mps=yes configure flag instructs Emacs to use the Memory Pool
  # System (MPS) for memory management instead of its default conservative
  # garbage collector. MPS is a modular, high-performance garbage collection
  # library that supports precise and incremental collection, allowing Emacs to
  # manage memory more efficiently, especially in memory-intensive workloads.
  # Enabling this option requires that the MPS library and headers are installed
  # and accessible during compilation. While primarily experimental, using MPS
  # can improve performance and enable advanced memory management features,
  # making it useful for custom Emacs builds such as those using the incremental
  # garbage collection (IGC) framework.
  # --with-mps=yes

  # Remove support for Access Control Lists and Extended Attributes for slightly
  # faster/simpler file I/O.
  #
  # If I am aiming for a lean, high-performance binary and don't use complex
  # Access Control Lists or Extended Attributes on your files: This slightly
  # reduces the overhead of file I/O operations and reduces the number of linked
  # system libraries. If we are on a standard personal Linux setup, these are
  # rarely needed inside Emacs.
  --disable-acl
  --disable-xattr

  # On Linux, --without-included-regex is typically faster than
  # --with-included-regex, assuming your system's C library (e.g., glibc)
  # provides a high-performance and standards-compliant regex implementation.
  #
  # Emacs does not use standard POSIX regular expressions. It uses a highly
  # specialized, heavily modified internal regex engine (regex-emacs.c).
  # Standard system regex libraries (like the one built into Linux's glibc)
  # simply do not understand Emacs-specific features, such as:
  #
  # The --without-included-regex flag comes from gnulib (a library of shared C
  # code used by the Emacs build system). If I pass this flag, Emacs will
  # still use its internal engine for all of your Lisp code and buffer searches.
  # At best, the flag is silently ignored by the core editor. At worst, it
  # forces minor background C utilities to use your operating system's regex
  # library, which might be slower or contain bugs that the GNU developers
  # already patched in the included version.
  --without-included-regex

  # The make process will be significantly longer (often 30 to 60 minutes
  # depending on your CPU). It systematically iterates through every single .el
  # file bundled with the Emacs distribution and compiles it into an .eln file
  # before the installation is complete.
  #Emacs is "born" fully optimized. Every built-in feature is already running
  # as native machine code the very first time I launch it. There is no
  # background "churn" for the standard library.
  # --with-native-compilation=aot

  # When I use this flag alone, it enables Just-In-Time (JIT) compilation
  # The Emacs C source compiles quickly. Only a absolute minimum set of Lisp
  # files required to start the editor are natively compiled during the make
  # process.
  # When I first start Emacs and begin using various packages (like dired,
  # magit, or org-mode), Emacs will notice those files are only available as
  # byte-code (.elc). It will then spawn background processes to compile them
  # into .eln files on the fly.
  --with-native-compilation

  --with-modules
  --with-threads

  --with-tree-sitter
  --with-xml2
  --with-zlib

  --without-gpm

  # You will not be able to embed native WebKit browser sessions inside Emacs
  # buffers. You will miss out on the ability to render complex HTML natively or
  # use packages that rely on embedded web views.
  --without-xwidgets

  # --with-xdbe
  # --with-x-toolkit=lucid

  # --without-xdbe
  # --with-x-toolkit=gtk3
  # --without-toolkit-scroll-bars
  # --without-pgtk

  --without-x
  --without-xdbe
  --with-toolkit-scroll-bars
  --with-pgtk

  # Important if using X11 and multiple input methods: X Input Method (XIM) is
  # an interface for input methods, which is essential for languages like
  # Chinese, Japanese, or Korean. Disabling XIM can affect text input in those
  # languages. Why disable? If you don't need multi-language input support
  # (for languages that require XIM), it's safe to disable it.
  #
  # Wayland: You should almost certainly use --without-xim. The PGTK build is
  # designed to use the native GTK input method context, which works directly
  # with Wayland. XIM is an X11-specific protocol; keeping it enabled in a pure
  # Wayland build adds unnecessary overhead and legacy code paths that can lead
  # to crashes or "stuck" keys.
  --without-xim

  # Pixel Precision Scrolling (Disabled because it is an X11 feature)
  --without-xinput2

  # Explicitly disabling X guarantees a pure Wayland binary with no legacy X11
  # baggage.
  --without-ns
  --without-xaw3d

  # Unlike older X11 drawing libraries, GTK 3 uses Cairo exclusively for its 2D
  # rendering engine. There is no non-Cairo drawing path in GTK 3.
  #
  # Cairo is a "2D Graphics Renderer" (The Painter): Its job is to actually
  # paint the pixels on your screen. Once HarfBuzz calculates the exact
  # positions of the glyphs, it hands that data off to Cairo. Cairo is the
  # engine that physically draws the text onto the window.
  --with-cairo # Uses cairo and pango (instead of xft)

  # is the preferred option for modern systems due to its
  # performance benefits and alignment with current X11 development trends.
  # However, --with-cairo remains a solid choice, especially if compatibility
  # with a wide range of systems is a priority.
  #
  # Cairo XCB stands for X C bindings. X11, not Wayland.
  # --without-cairo-xcb

  # Fewer developers test Emacs with --with-cairo-xcb than with default
  # --with-cairo + Xlib.
  #
  # You should remove this. Since you are using --with-pgtk, Emacs uses the GTK3
  # drawing backend, which handles Cairo internally. The xcb specific flag is
  # for X11 environments and ma
  # --with-cairo-xcb # Remove when pgtk

  --with-harfbuzz

  # --without-xft: If you're using Harfbuzz (as suggested), you don't need
  # --XFT, which is now replaced.
  --without-xft # Replaced with harfbuzz

  # This library provides complex text layout shaping for scripts like Arabic,
  # Indic, or Thai. For an English-only workflow, this type of complex
  # multilingual shaping is never triggered.
  --without-m17n-flt # I am using English only

  # We do not need the legacy libotf library to handles OpenType font features.

  # By compiling with --with-harfbuzz, we are instructing Emacs to use a modern
  # text shaping engine to handle all of those exact OpenType features natively.
  # HarfBuzz performs the exact job that libotf used to do.
  --without-libotf

  --with-file-notification=inotify

  --with-pdumper=yes

  # Yes, --with-wide-int can make certain integer operations faster in Emacs
  # Lisp because it allows using a wider native integer type instead of
  # resorting to bignum arithmetic for larger numbers. This reduces the
  # overhead of allocating and managing bignums.
  #
  # However, the speed improvement mainly applies when manipulating integers
  # near or beyond the default integer size limit. For typical integer
  # operations within the smaller range, performance differences are minimal.
  #
  # --with-wide-int: This is the default on 64-bit systems. Manually specifying
  # it is harmless but unnecessary.
  # --with-wide-int

  # Not relevant in Linux
  # --without-native-image-api

  --without-imagemagick

  --without-gif
  --without-jpeg
  --without-png
  --without-rsvg
  --without-tiff
  --without-xpm
  --without-webp

  # The LCMS2 library enables color management for image processing in Emacs,
  # allowing for accurate color rendering of images and fonts. If you work
  # with images or high-quality graphics in Emacs (e.g., in Org-mode, dired
  # with image previews, or using image-based formats), you may want to keep
  # this enabled.
  #
  # I enabled support for many image formats (JPEG, PNG, WebP). Without
  # LCMS2, Emacs cannot apply ICC color profiles. If you view images in Emacs,
  # they might display with slightly inaccurate colors compared to your
  # dedicated image viewers.
  --without-lcms2

  # Consider enabling SQLite if you use packages that rely on databases (e.g.,
  # Org-mode, Magit, Projectile).
  #
  # Org-mode can use SQLite for its archive feature, allowing for faster and
  # more efficient handling of large Org files. It enables quicker searches
  # and better organization of extensive Org-mode databases.
  # Package.el (Emacs' built-in package manager) can use SQLite for its
  # database, potentially speeding up package operations.
  # Other packages that use it: Magit, Projectile, Company.
  #
  # (That should speed up things like Org Roam or Magit Forge)
  --with-sqlite3

  # Native JSON parsing via Jansson greatly increases performance for json-heavy
  # tasks (like LSP).
  # not compatible
  # --with-json

  --without-compress-install
  # --with-compress-install

  # Depends on your use case: DBus is a messaging system used by many Linux
  # desktop environments for communication between applications. Disabling
  # DBus will remove certain integration features, such as notifications or
  # communication with other applications.
  --without-dbus

  # You should absolutely not add --without-libgmp. Adding that flag will
  # actually destroy your Emacs performance.
  --with-libgmp

  # These flags disable support for ancient mail retrieval methods, directory
  # services, and local mail spool manipulation. Because modern Emacs mail
  # setups rely on external synchronization, removing these ensures the build
  # script does not waste time searching for legacy network libraries and keeps
  # the binary entirely free of dead mail code
  --without-kerberos
  --without-kerberos5
  --without-hesiod
  --without-mail-unlink

  # configure: WARNING: This configuration installs a 'movemail' program that
  # does not retrieve POP3 email. By default, Emacs 25 and earlier installed a
  # 'movemail' program that retrieved POP3 email via only insecure channels, a
  # practice that is no longer recommended but that you can continue to
  # support by using './configure --with-pop'. configure: You might want to
  # use './configure --with-mailutils'.
  --without-mailutils
  --without-pop

  # Audible bell, and any packages that attempt to play audio notifications
  # (such as Pomodoro timers or chat clients)
  --with-sound=no

  # Not important unless using GNOME: These options disable GConf and
  # Settings, which are used for configuration in GNOME-based environments.
  --without-gconf

  # Useful for .service files: Type=notify
  --without-libsystemd

  # GSettings
  #
  # What it does: GSettings is the configuration storage system for GNOME and
  # GTK-based desktops.
  #
  # Why you want it: It allows Emacs to read system-wide settings like your
  # default monospace font, font rendering hints (antialiasing), and UI themes.
  #
  # When to disable: Only disable this if you are building a strictly
  # terminal-only Emacs (headless server) or if you want to avoid installing
  # glib dependencies. If you disable this on a desktop, Emacs will ignore your
  # system font configuration.
  --without-gsettings

  # What it does: This links against libselinux to handle file contexts
  # (security labels) when creating or copying files.
  #
  # Why you want it: If you are on a distribution that enforces SELinux (Fedora,
  # RHEL, CentOS), you must keep this enabled. Otherwise, files created by Emacs
  # may have the wrong security context, leading to "Permission Denied" errors
  # when other services try to access them.
  #
  # When to disable: If you are on Debian, Ubuntu, or Arch Linux (which
  # typically use AppArmor or nothing), this library does nothing for you. You
  # can safely strip it out.
  --without-selinux

  # Smack is a Mandatory Access Control framework similar to SELinux, but it is
  # rarely used outside of embedded environments (like Tizen) or highly specific
  # corporate deployments.
  --without-libsmack

  # Disable (--disable-largefile): Only if you do not work with files larger
  # than 2GB and want to reduce Emacs' binary size and potential overhead.
  # This option limits Emacs to handling files up to 2GB in size. If you're
  # not working with very large files, this might be a good option to reduce
  # potential overhead and the complexity of Emacs when dealing with files
  # that could be impractical to open or edit within Emacs.
  # It may slightly reduce the size of the Emacs binary and improve
  # performance, but this benefit is minimal in most cases.
  #
  # --disable-largefile: I recommend removing this. The "overhead" of 64-bit
  # file offsets is non-existent on a 64-bit Arch system. Disabling this makes
  # it impossible to open files larger than 2GB, which can be a significant
  # limitation if you ever need to view large log files or database dumps.
  # --disable-largefile
)

#
# Prefix
#
detect_git_branch() {
  BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
  if [[ $BRANCH_NAME != "" ]] && [[ $BRANCH_NAME != "HEAD" ]]; then
    EMACS_BRANCH="/branch-$BRANCH_NAME"
  else
    TAG_NAME=$(git describe --tags --abbrev=0)
    if [[ $TAG_NAME != "HEAD" ]]; then
      EMACS_BRANCH="/tag-$TAG_NAME"
    fi
  fi

  if [[ $EMACS_BRANCH = "" ]]; then
    echo "Error: cannot detect the version." >&2
    exit 1
  fi
}

operating_system() {
  case "$OSTYPE" in
  darwin*)
    echo macos
    ;;
  *)
    if [[ -f /etc/os-release ]]; then
      # shellcheck disable=SC1091
      source /etc/os-release
      test "$ID" = "archlinux" && ID=arch
      echo "$ID"
    else
      exit 1
    fi
    ;;
  esac
}

# shellcheck disable=SC2317
error_handler() {
  local errno="$?"
  echo "Error: ${BASH_SOURCE[1]}:${BASH_LINENO[0]}" \
    "(${BASH_COMMAND} exited with status $errno)" >&2
  exit "${errno}"
}

run_build() {
  local phase="$1"
  local do_install="$2"

  local current_cflags="$BASE_CFLAGS"
  local current_ldflags="$BASE_LDFLAGS"

  if [[ "$ID" == "arch" && "$USE_CLANG" -ne 0 ]]; then
    export CC=clang
    export CXX=clang++
    export AR=llvm-ar
    export NM=llvm-nm
    export LD=ld.lld
    export RANLIB=llvm-ranlib

    # Mirror configure.ac Clang LTO plugin management
    # Locate the LLVMgold plugin dynamically via the compiler driver
    GOLD_PLUGIN=$($CC -print-file-name=LLVMgold.so 2>/dev/null)
    if [[ -x "$GOLD_PLUGIN" ]]; then
      # Append the plugin name directly to ARFLAGS as required by standard ar
      export ARFLAGS="cru --plugin $GOLD_PLUGIN"
      export RANLIB="llvm-ranlib --plugin $GOLD_PLUGIN"
    fi

    # Use Clang's specific LTO flag and avoid string pollution further down
    current_cflags="$current_cflags -flto=full"
    current_ldflags="$current_ldflags -flto=full"
  fi

  # Analysis of the -fuse-linker-plugin export flag
  #
  # For compiling Emacs C source code
  #
  # Benefits:
  # - Enables the linker plugin during Link Time Optimization (-flto).
  # - Allows the compiler and linker to cooperate, performing optimizations across
  # different C translation units.
  # - Can yield a slightly faster Emacs binary due to aggressive inlining and dead
  # code elimination across the entire C codebase.
  #
  # Tradeoffs:
  # - Increases both memory usage and overall compilation time during the linking
  # phase.
  # - Demands a compatible linker (such as ld.gold or lld) that is properly
  # configured to work with your GCC installation.
  # - It is mostly redundant. Modern versions of GCC automatically activate the
  # linker plugin when you pass the -flto flag, so specifying it manually adds no
  # extra value.
  #
  # 2. For compiling .el files to .eln files (Native Compilation)
  #
  # Benefits:
  # - Practically zero. Emacs native compilation uses libgccjit to compile Emacs
  # Lisp into independent shared libraries (.eln files) that are loaded
  # dynamically at runtime.
  # - Because there is no large-scale linking of multiple object files into a
  # single binary, whole-program optimization techniques do not apply here.
  #
  # Tradeoffs:
  # - Introduces a high probability of build failures. The libgccjit environment
  # is delicate and sensitive to injected compiler and linker flags.
  # - Forcing linker plugins into the async native compilation threads can cause
  # the generation of .eln files to crash or hang indefinitely.
  # - It wastes system resources by adding unnecessary steps to the compilation of
  # single-file shared objects.
  #
  # IMPORTANT: redundant if using -flto=auto (already implies plugin usage)
  #
  # The Historical Habit: Explicitly declaring -fuse-linker-plugin is a legacy
  # defensive programming habit. On older or highly fragmented toolchains, if the
  # linker failed to load the plugin, GCC would silently fall back to traditional
  # linking or fail in confusing ways. Explicitly declaring the flag forced a hard
  # error if the plugin was missing, rather than allowing a silent downgrade.
  if [[ "$ID" != "arch" || "$USE_CLANG" -eq 0 ]]; then
    current_cflags="$current_cflags -fuse-linker-plugin"
    current_ldflags="$current_ldflags -fuse-linker-plugin"
  fi

  FPROFILE_BASE_DIR="$HOME/.flto/emacs"
  FPROFILE_DIR="$FPROFILE_BASE_DIR$EMACS_BRANCH"
  mkdir -p "$FPROFILE_BASE_DIR"

  # Notice the addition of -fprofile-correction. This is highly recommended
  # when compiling Emacs with PGO. Emacs handles async processes and threads
  # (if compiled with --with-threads), which can occasionally cause
  # multithreaded profile data counters to become slightly inconsistent. The
  # -fprofile-correction flag tells GCC to silently correct these minor
  # profile inconsistencies rather than halting the build with an error.
  #
  # TODO: -fprofile-correction to CFLAGS and LDFLAGS
  #
  # 1. Using -flto=auto without PGO
  # -------------------------------
  # When you use Link-Time Optimization, you change how the compiler works.
  # During the initial CFLAGS phase, the compiler does not generate final
  # machine code. It generates an intermediate representation (GIMPLE).
  # The actual translation into machine code happens during the linking phase.
  # When the build system calls the linker, it invokes the GCC compiler driver
  # to handle that intermediate code. If the compiler driver does not see -O2
  # in the LDFLAGS, it assumes you want an unoptimized build for that final,
  # massive compilation step. It defaults to -O0, negating your initial -O2 in
  # CFLAGS.
  # Whenever -flto is present in CFLAGS, the exact same -O optimization level
  # must be present in LDFLAGS.
  #
  # 2. Not using -flto=auto at all
  # ------------------------------
  # No, you do not need to add the standalone -O2 to your LDFLAGS.
  # If you execute a standard build without LTO, the compilation process is
  # traditional. The compiler reads the C source code, applies the -O2
  # optimizations specified in your CFLAGS, and generates fully optimized,
  # final machine code directly into the object files (.o).
  # By the time the build reaches the linking phase, the code optimization is
  # entirely finished. The linker's only job is to stitch those object files
  # together into the final Emacs executable. Passing a standalone -O2 to
  # LDFLAGS in a non-LTO build does nothing, because the linker itself does
  # not understand compiler optimization heuristics.

  # Dynamic profiling and optimization assignment based on active phase
  if [[ "$phase" == "fprofile-generate" ]]; then
    rm -fr "$FPROFILE_DIR"
    mkdir -p "$FPROFILE_DIR"

    if [[ "$ID" == "arch" && "$USE_CLANG" -ne 0 ]]; then
      # Clang concurrent build threads will overwrite each other's data unless
      # explicitly separated using %p (PID) and %m (Binary Signature).
      export LLVM_PROFILE_FILE="$FPROFILE_DIR/%p-%m.profraw"
      export CFLAGS="$current_cflags -fprofile-generate=$FPROFILE_DIR"
      export LDFLAGS="$current_ldflags -fprofile-generate=$FPROFILE_DIR -O$CC_OPTIMIZE"
    else
      export CFLAGS="$current_cflags -flto=auto -fprofile-generate=$FPROFILE_DIR"
      export LDFLAGS="$current_ldflags -flto=auto -fprofile-generate=$FPROFILE_DIR -O$CC_OPTIMIZE"
    fi
  elif [[ "$phase" == "fprofile-use" ]]; then
    # Then recompile with: Step 2
    #
    # Clear out the accumulated conftest data markers from Phase 1.
    # This prevents the compiler from panicking over internal toolchain
    # test variations without needing to inject coverage-mismatch CFLAGS.
    # TODO enable
    find "$FPROFILE_DIR" -type f -name "*conftest*" -delete 2>/dev/null || true

    # Then recompile with: Step 2
    # -fprofile-correction resolves the object generation issue. However, you
    # still missed the standalone -O2 in your LDFLAGS. The -Wl,-O2 flag only
    # passes instructions to the linker subsystem (ld). Because you are using
    # -flto=auto, GCC handles the link phase. It requires the standalone -O2
    # flag to know which optimization heuristics to apply to the intermediate
    # representation. Without it, the LTO pass defaults to -O0.
    #
    # The placement of -O2 at the end of the LDFLAGS string is completely valid.
    # The compiler driver parses the arguments correctly regardless of their
    # position relative to the -Wl linker-specific directives. You have
    # successfully combined aggressive interprocedural analysis, profile-guided
    # optimization, and modern security hardening.
    #
    # Because this build configuration is prod ready, here is the commit
    # message:
    #
    # build: configure Emacs Phase 2 PGO flags with hardened LTO and linking
    # optimizations
    #
    # Source: The official GNU Compiler Collection (GCC) Manual. Section:
    # Options That Control Optimization.
    # Details: The GCC documentation for -flto explicitly states: "To use the
    # link-time optimizer, -flto and optimization options should be specified
    # at compile time and during the final link. It is recommended that you
    # compile all the files participating in the same link with the same
    # options and also specify those options at link time."
    # Rationale: During LTO, the linker hands the intermediate representation
    # (GIMPLE) back to the compiler driver for the actual machine-code
    # generation. If the compiler driver does not see an -O flag during this
    # link invocation, it defaults to -O0.
    # https://gcc.gnu.org/onlinedocs/gcc/Optimize-Options.html
    if [[ "$ID" == "arch" && "$USE_CLANG" -ne 0 ]]; then
      # Clang demands that we explicitly merge raw generated profile data before use

      # Why llvm-profdata is required
      #
      # There is a fundamental difference in how GCC and Clang handle the two
      # phases of Profile-Guided Optimization (PGO):
      #
      # - GCC PGO: GCC handles the "merging" of data internally. When you
      #   compile with -fprofile-use, GCC looks at the .gcda files generated in
      #   the build directory, reads them, and performs the optimization. It
      #   manages the index of those files automatically.
      # - Clang/LLVM PGO: Clang creates raw profile files (.profraw). These
      #   files are not directly readable by the compiler for the second
      #   optimization pass. They contain a dump of counters that must be
      #   processed, normalized, and indexed into a single binary format called
      #   .profdata. The compiler only understands the indexed .profdata format.
      # If you skip the merge step, one of two things will happen:
      # - Build Failure: The compiler will fail to find the expected indexed
      #   format.
      # - Silent Failure (The worst case): The compiler might ignore the missing
      #   data and build a non-optimized binary, giving you a false sense of
      #   security that your Emacs is "optimized" when it is actually just a
      #   standard build.
      llvm-profdata merge -output="$FPROFILE_DIR/merged.profdata" "$FPROFILE_DIR"/*.profraw
      export CFLAGS="$current_cflags -fprofile-use=$FPROFILE_DIR/merged.profdata -Wno-missing-profile"
      export LDFLAGS="$current_ldflags -fprofile-use=$FPROFILE_DIR/merged.profdata -O$CC_OPTIMIZE"
    else
      # The -Wno-error=coverage-mismatch flag: Ensures that if any other minor
      # mismatch occurs during the linking phase, GCC will only print a warning
      # instead of aborting the entire compilation process.
      #
      # The -Wno-missing-profile flag: Prevents GCC from complaining when it
      # inevitably can't find profile data for the freshly generated Autoconf
      # test files.
      #
      # Phases
      # ------
      # In Phase 1 (fprofile-generate): ./configure runs. It compiles a bunch of
      # conftest.c files. GCC diligently tracks them and creates a profile data
      # file named conftest.gcda in your ~/.flto/ folder.
      #
      # In Phase 2 (fprofile-use): ./configure runs again. It writes a brand
      # new, completely different conftest.c file to test something. When GCC
      # tries to compile it, it automatically loads the old conftest.gcda file
      # from Phase 1.
      #
      # The Crash: GCC looks at the old profile data (which might say "this
      # program has 7 branches") and looks at the new conftest.c file (which
      # only has 1 branch). GCC panics, throws a coverage-mismatch error, and
      # halts. Because the compiler halted, ./configure assumes your compiler is
      # completely broken and throws the cannot compute suffix of executables:
      # cannot compile and link error.
      # Solution: -fprofile-correction -Wno-missing-profile
      # -Wno-error=coverage-mismatch
      # removed from cflags: -fprofile-correction -Wno-missing-profile -Wno-error=coverage-mismatch
      # removed from ldflags: -fprofile-correction
      export CFLAGS="$current_cflags -flto=auto -fprofile-use=$FPROFILE_DIR -Wno-missing-profile -Wno-error=coverage-mismatch"
      export LDFLAGS="$current_ldflags -flto=auto -fprofile-use=$FPROFILE_DIR -O$CC_OPTIMIZE"
    fi
  else
    # Fallback for when PGO is completely disabled but LTO is still desired
    if [[ "$ID" == "arch" && "$USE_CLANG" -ne 0 ]]; then
      export CFLAGS="$current_cflags"
      export LDFLAGS="$current_ldflags -O$CC_OPTIMIZE"
    else
      export CFLAGS="$current_cflags -flto=auto"
      export LDFLAGS="$current_ldflags -flto=auto -O$CC_OPTIMIZE"
    fi
  fi

  export CXXFLAGS="$CFLAGS"

  echo "[SOURCE DIR]" "$PWD"
  echo "[CONFIGURE OPTION]" "${CONFIGURE_ARGS[@]}"
  echo "[CFLAGS] $CFLAGS"
  echo "[LDFLAGS] $LDFLAGS"

  set -x

  ./configure "${CONFIGURE_ARGS[@]}"

  NUM_PROC_MAX=$(nproc)
  NUM_PROC_MAX=$((NUM_PROC_MAX * 4))

  make -j "$NUM_PROC_MAX" -l "$NUM_PROC"

  if [[ "$do_install" -ne 0 ]]; then
    test -f "$EMACS_INSTALL_PREFIX/bin/emacs" && rm -fr "$EMACS_INSTALL_PREFIX"

    # make install-strip: This is a variant of make install, but with the added
    # step of "stripping" the binaries. Stripping refers to removing debugging
    # symbols and other information from the executable files, reducing their
    # size. This is usually done for production releases to make the binaries
    # smaller and more efficient, since debugging symbols are typically not needed
    # in a production environment.
    make install-strip
  fi

  set +x
}

main() {
  trap "error_handler" ERR
  set -o errtrace

  cd ~/src/forks/emacs/

  # if ! git remote -v | grep '/emacs '; then
  #   echo "This is not an Emacs repository." >&2
  #   exit 1
  # fi

  detect_git_branch

  # Append the OS family
  if [[ $EMACS_INSTALL_PREFIX_APPEND_OPERATING_SYSTEM -ne 0 ]]; then
    EMACS_INSTALL_PREFIX="${EMACS_INSTALL_PREFIX}/$(operating_system)"
  fi

  EMACS_INSTALL_PREFIX="${EMACS_INSTALL_PREFIX}/${SOFTWARE_NAME}"

  if [[ $EMACS_INSTALL_PREFIX_APPEND_EMACS_BRANCH -ne 0 ]]; then
    EMACS_INSTALL_PREFIX="$EMACS_INSTALL_PREFIX$EMACS_BRANCH"
    CONFIGURE_ARGS+=("--prefix=${EMACS_INSTALL_PREFIX}")
  fi

  GIT_TOP_LEVEL=$(git rev-parse --show-toplevel)
  cd "$GIT_TOP_LEVEL"

  # if [[ -f /etc/makepkg.conf ]]; then
  #   # shellcheck disable=SC1091
  #   source /etc/makepkg.conf
  # fi

  echo "[SOURCE DIR]" "$PWD"
  echo "[CONFIGURE OPTION]" "${CONFIGURE_ARGS[@]}"
  echo "[BASE_CFLAGS] $BASE_CFLAGS"
  echo "[BASE_LDFLAGS] $BASE_LDFLAGS"
  echo

  read -r -p "Compile Emacs? [y,n] " ANSWER

  git clean -fxd
  git reset --hard HEAD
  ./autogen.sh

  [[ "$ANSWER" != "y" ]] && exit 1

  if [[ $HANDLE_FPROFILE -ne 0 ]]; then
    echo "Building with profile generation..."

    if [[ $FPROFILE_GENERATE -ne 0 ]]; then
      run_build "fprofile-generate" 1
      echo ""
      echo ">>> ACTION REQUIRED: Emacs has been built with profiling enabled."
      echo ">>> Open another terminal, run Emacs" \
        "($EMACS_INSTALL_PREFIX/bin/emacs), and perform typical tasks."
      echo ">>> Close Emacs gracefully to dump the profile data," \
        "then return here."
      read -r -p "Proceed with fprofile-use? [y,n] " ANSWER
      if [[ "$ANSWER" != "y" ]]; then
        echo "Interrupted." >&2
        exit 1
      fi
    fi

    make distclean

    echo "Building with profile use..."
    run_build "fprofile-use" 1
  else
    run_build "disable-fprofile" 1
  fi
}

main "$@"
