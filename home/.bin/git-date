set -euo pipefail

main() {
  # Verify the current directory is a Git repository
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Not a Git repository." >&2
    exit 1
  fi

  # Retrieve the origin URL; default to a placeholder if not set
  local origin_url
  if ! origin_url=$(git remote get-url origin 2>/dev/null); then
    echo "Error: no origin." >&2
    exit 1
  fi

  # Attempt to get the current branch name
  local branch_or_ref
  branch_or_ref=$(git branch --show-current 2>/dev/null || true)

  # If no branch is found (detached HEAD state), get the short commit hash
  if [[ -z "$branch_or_ref" ]]; then
    if ! branch_or_ref=$(git rev-parse --short HEAD 2>/dev/null); then
      echo "Error: No reference." >&2
      exit 1
    fi
  fi

  # Retrieve the date of the last commit (YYYY-MM-DD format)
  local last_commit_date
  if ! last_commit_date=$(git log -1 --format="%cd" \
    --date=short 2>/dev/null); then
    echo "Error: No commits." >&2
  fi

  # Output the gathered information in a single line
  echo "${last_commit_date}: ${origin_url} (${branch_or_ref})"
}

main "$@"
