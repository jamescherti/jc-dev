set -euf -o pipefail

EMACS_EDIT_TIMEOUT="${EMACS_EDIT_TIMEOUT:-3}"
EMACS_EDIT_NEW_TAB="${EMACS_EDIT_NEW_TAB:-1}"
EMACS_EDIT_WAIT_SECONDS=30
EMACS_EDIT_EMACS_BIN=run-emacs-use-package

run-emacsclient() {
  emacsclient --no-wait "--timeout=$EMACS_EDIT_TIMEOUT" "$@" 2>/dev/null \
    || return "$?"
}

emacs-open-in-a-new-tab() {
  if [[ "$EMACS_EDIT_NEW_TAB" != "0" ]]; then
    run-emacsclient --suppress-output --eval '(tab-bar-new-tab)' || :
  fi

  run-emacsclient --suppress-output "$@" || :
}

is-emacs-server-running() {
  # Hide output; return 0 if successful, 1 if connection fails
  emacsclient -e "(+ 1 1)" &>/dev/null
}

main() {
  # Requirements
  for CMD in "$EMACS_EDIT_EMACS_BIN" emacsclient; do
    if ! type -P "$CMD" &>/dev/null; then
      echo "Error: $CMD not found in \$PATH" >&2
      exit 1
    fi
  done

  # Edit
  if is-emacs-server-running; then
    EMACS_DAEMON=$(run-emacsclient -e '(daemonp)' || :)

    # emacs-open-in-a-new-tab "$@" || :
    if [[ $EMACS_DAEMON == "t" ]]; then
      run-emacsclient -c "$@" || :
    else
      run-emacsclient "$@" || :
    fi
  else
    "$EMACS_EDIT_EMACS_BIN" &>/dev/null &
    disown

    wait_cycles=0
    max_cycles=$((EMACS_EDIT_WAIT_SECONDS * 10))

    # Wait for Emacs standard initialization
    while true; do
      if [[ "$wait_cycles" -ge "$max_cycles" ]]; then
        echo "Error: Timeout waiting for Emacs core to initialize." >&2
        exit 1
      fi

      AFTER_EMACS_INIT=$(run-emacsclient -e "(when after-init-time t)" || :)
      # Check for both literal t and quoted "t"
      if [[ "$AFTER_EMACS_INIT" == "t" ]] || [[ "$AFTER_EMACS_INIT" == '"t"' ]]; then
        break
      fi
      sleep 0.1
      ((wait_cycles++))
    done

    # EasySession: Wait until the session is loaded
    wait_cycles=0
    while true; do
      if [[ "$wait_cycles" -ge "$max_cycles" ]]; then
        echo "Error: Timeout waiting for EasySession to load." >&2
        exit 1
      fi

      SESSION_LOADED=$(
        run-emacsclient \
          -e "(and (boundp 'easysession--current-session-name)
                 easysession--current-session-name)" 2>/dev/null || :
      )

      if [[ "$SESSION_LOADED" != "" ]] \
        && [[ "$SESSION_LOADED" != "nil" ]] \
        && [[ "$SESSION_LOADED" != '"nil"' ]]; then
        break
      fi

      sleep 0.1
      ((wait_cycles++))
    done

    # Open the file in a new tab
    emacs-open-in-a-new-tab "$@" || :
  fi
}

main "$@"
