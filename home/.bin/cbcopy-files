# Exit immediately if a command exits with a non-zero status,
# treat unset variables as an error, and fail pipelines if any command fails.
set -euo pipefail

# Check if at least one argument is provided
if [[ $# -eq 0 ]]; then
  echo "Usage: ${0##*/} <file1> [file2 ...]" >&2
  exit 1
fi

run_ai_ls() {
  for target_file in "$@"; do
    # Check if the argument is a regular file and is readable
    if [[ -f "$target_file" && -r "$target_file" ]]; then
      echo "File: ${target_file}"
      echo '```'

      # Print the file content
      cat "$target_file"

      # Ensure a trailing newline exists so the closing backticks do not get
      # appended to the last line of the file's content.
      if [[ -s "$target_file" &&
        $(tail -c 1 "$target_file" | wc -l) -eq 0 ]]; then
        echo
      fi

      echo
      echo '```'
      echo
    else
      # Output warnings to standard error so they do not pollute the captured
      # output
      echo "Error: '${target_file}' is not readable." >&2
      exit 1
    fi
  done
}

run_checks() {
  for target_file in "$@"; do
    if ! [[ -f "$target_file" && -r "$target_file" ]]; then
      echo "Error: '${target_file}' is not readable." >&2
      exit 1
    fi
  done
}

run_checks "$@"

run_ai_ls "$@"
run_ai_ls "$@" | cbcopy
