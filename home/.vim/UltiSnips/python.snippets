snippet thread
import threading
import time

def $1(stop_event: threading.Event):
	while not stop_event.is_set():
		time.sleep(0.5)

stop_event = threading.Event()
thread = threading.Thread(target=${1:method_name}, args=(stop_event,))
thread.start()
try:
	while True:
		time.sleep(1)
except (KeyboardInterrupt, SystemExit):
	sys.exit(1)
finally:
	stop_event.set()
	thread.join()
endsnippet

