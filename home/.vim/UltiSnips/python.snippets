snippet sendmail
from smtplib import SMTP
from email.mime.text import MIMEText


def sendmail(email_from: str,
             recipients: list,
             subject: str,
             message: str,
             smtp_server: str = "localhost"):
	"""Send an email from 'email_from' to 'recipients'."""
	for recipient in recipients:
		msg = MIMEText(message)
		msg["Subject"] = subject
		msg["From"] = email_from
		msg["To"] = recipient
		smtp = SMTP(smtp_server)
		smtp.sendmail(email_from, recipient, msg.as_string())
		smtp.quit()
endsnippet

