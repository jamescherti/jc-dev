snippet pexpect
import sys
import struct
import fcntl
import termios
import signal
import pexpect

cmd = ['bash']
child = pexpect.spawn(command=cmd[0], args=cmd[1:],
                      timeout=60, cwd='/', echo=False)

child.expect(".*password")
child.sendline(password)

# pylint: disable=unused-argument
def sigwinch_passthrough(sig, data):
	"""Pass the window size to the parent."""
	aup = struct.unpack('hhhh',
	                    fcntl.ioctl(sys.stdout.fileno(),
	                                termios.TIOCGWINSZ,
	                                struct.pack("HHHH", 0, 0, 0, 0)))

sigwinch_passthrough(None, None)  # resize
orig_sigwinch = signal.getsignal(signal.SIGWINCH)
signal.signal(signal.SIGWINCH, sigwinch_passthrough)
child.interact()
signal.signal(signal.SIGWINCH, orig_sigwinch)
endsnippet

