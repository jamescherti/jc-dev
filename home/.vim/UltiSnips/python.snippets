snippet argparse
import argparse
def parse_args():
	"""Parse command-line arguments."""
	usage = "%(prog)s [--option] [args]"
	parser = argparse.ArgumentParser(description=__doc__.splitlines()[0],
	                                 usage=usage)
	parser.add_argument("args", metavar="N", type=str, nargs="+",
	                    help="${1:}")
	return parser.parse_args()
endsnippet

