snippet gc
import signal
import gc

def garbage_collector(signum, frame):
	"""Garbage collection."""
	gc.collect()
	logging.debug("Garbage collection done.")
	if signum == signal.SIGINT:
		sys.exit(1)
	else:
		sys.exit(0)

signal.signal(signal.SIGINT, garbage_collector)
signal.signal(signal.SIGTERM, garbage_collector)
endsnippet

