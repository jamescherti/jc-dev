for pid in psutil.pids():
	try:
		proc = psutil.Process(pid)
		if proc.username() != current_user:
			continue

		if proc.name() == ${1:"proc_name"}:
			${2:pass}
	except psutil.Error:
		pass
endsnippet

snippet psfile
def is_file_open(fpath):
	for proc in psutil.process_iter():
		try:
			for item in proc.open_files():
				if fpath == item.path:
					return True
		except psutil.Error:
			pass

	return False
endsnippet

