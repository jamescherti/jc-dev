snippet wrapper
class ${1:ClassName}:
	def __init__(self):
		self._${2:object} = ${3:WrapperClass}

	def __getattr__(self, name):
		"""Get an attribute."""
		return self._$2[name]

	@property
	def __dict__(self):
		"""The internal variables."""
		return self._$2

	def __iter__(self):
		"""Iteration."""
		return iter(self._$2)

	def __repr__(self):
		"""Return the string representation of the class."""
		return repr(self._$2)
endsnippet

snippet decor
def ${1:decorator}(orig_func):
	"""${3:A decorator}"""
	def _func(*args, **kwargs):
		"""A nested function for other functions"""
		print("before")
		orig_func(*args, **kwargs)
		print("after")
		return True

	return _func

@$1
def ${2:func}():
	"""Docstring"""
	pass
endsnippet

