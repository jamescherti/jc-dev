(stdout, stderr) = proc.communicate()
if proc.returncode != 0:
    raise subprocess.CalledProcessError(returncode=proc.returncode,
	                                    cmd=cmd,
	                                    output=stdout,
							            stderr=stderr)
stdout = stdout.decode()
stderr = stderr.decode()
endsnippet

