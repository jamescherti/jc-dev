snippet md5
import hashlib
def md5sum(filename):
	"""Return the MD5 sum of a file."""
	md5 = hashlib.md5()
	with open(filename, "rb") as fhandler:
		for chunk in iter(lambda: fhandler.read(8192), b""):
			md5.update(chunk)
	return md5.hexdigest()
endsnippet

