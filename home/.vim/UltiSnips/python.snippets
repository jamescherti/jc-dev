snippet check_output
def _run(self, *args):
	"""Run netctl."""
	os_env = os.environ.copy()
	os_env["LC_ALL"] = "C"
	cmd = ["netctl"] + list(args)
	output = subprocess.check_output(cmd, env=os_env, timeout=30)
	return output.decode("utf-8").splitlines()
endsnippet

