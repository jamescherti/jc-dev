snippet confirm
while True:
	try:
		answer = input("Execute? [y,n] ")
	except KeyboardInterrupt:
		print()
		sys.exit(1)

	if answer not in ["y", "n"]:
		continue

	if answer == "y":
		break
	else:
		sys.exit(1)
endsnippet

