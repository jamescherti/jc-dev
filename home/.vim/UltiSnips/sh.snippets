priority 50

snippet size
"\${#${1:name}[@]}"
endsnippet

snippet getopt
show_usage() {
  {
	echo "Usage: $0 [-h] [--${1:longopt} $3]" >&2
	echo
	echo "-h, --help    Show this help message and exit"
	echo "--$1 f      Show only files (default)"
	echo "--$1 d      Show only directories"
  } >&2
}

${2:LONGOPT}_FLAG=f
${4:ARG1}=""
while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help)
	show_usage
	exit 1
	;;
  --$1)
	shift
	case "$1" in
	${3:f|d})
	  $2_FLAG="$1"
	  ;;
	*)
	  echo "Invalid --$1" >&2
	  exit 1
	  ;;
	esac
	;;
  *)
	$4="\$1"
	;;
  esac

  shift
done

if [[ \$$4 = "" ]]; then
  show_usage
  exit 1
fi
endsnippet

snippet getopt2
show_usage() {
	{
		echo "Usage: \$0 [-h]" >&2
		echo
		echo "-h    Show this help message and exit"
	} >&2
}

while getopts ":h${1:}" opt; do
	case ${opt} in
	h)
		show_usage
		exit 1
		;;
	\?)
		echo "Invalid option: -$OPTARG" >&2
		exit 1
		;;
	:)
		echo "Invalid option: -$OPTARG requires an argument" >&2
		exit 1
		;;
	esac
done
shift $((OPTIND - 1))
endsnippet

snippet underline "underline"
echo "${1:string}" | sed -n 'p;s/./-/gp'  # Underline
endsnippet

snippet stdin "stdin"
while IFS='' read -r line; do
	${1:true}
done
endsnippet

snippet add "add"
${1:var}=$(($1+1))
endsnippet

snippet day "day"
local day=$(date '+%d' | sed 's/^0*//')
if [[ "$day" ${1:-ge} ${1:1} ]]; then
	${1:true}
fi
endsnippet

snippet strict "strict"
set -euf -o pipefail
endsnippet

snippet rtrim "rtrim"
sed -e 's/\([0-9\s. ]\+\)$//g'
endsnippet

snippet rsync "rsync"
rsync -ar --delete --info=progress2 --human-readable --sparse --hard-links --acls --xattrs ${1:src/} ${2:dest/}
endsnippet

snippet len "len" w
"\$\{#${1:var}[@]\}${2:}"
endsnippet

snippet inc2 "inc" w
let ${1:var}=($1+1)
endsnippet

snippet inc
${1:var}=$(($1+${2:1}))
endsnippet

snippet user "user" w
$(id -un)
endsnippet

snippet path
PATH=/sbin:/bin:/usr/sbin:/usr/bin:/usr/local/sbin:/usr/local/bin
endsnippet

